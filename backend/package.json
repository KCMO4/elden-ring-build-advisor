{
  "name": "elden-ring-build-advisor-backend",
  "version": "1.0.0",
  "description": "API REST para parsear save files .sl2 de Elden Ring",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "sync-data": "ts-node --project tsconfig.scripts.json scripts/sync-data.ts",
    "scrape-images": "ts-node --project tsconfig.scripts.json scripts/scrape-fandom-images.ts",
    "check-images": "ts-node --project tsconfig.scripts.json scripts/check-images.ts",
    "audit": "ts-node --project tsconfig.scripts.json scripts/audit-data.ts",
    "audit:save": "ts-node --project tsconfig.scripts.json scripts/audit-data.ts --save",
    "patch-armor": "ts-node --project tsconfig.scripts.json scripts/patch-armor-precision.ts",
    "patch-armor:dry": "ts-node --project tsconfig.scripts.json scripts/patch-armor-precision.ts --dry-run"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.5",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
